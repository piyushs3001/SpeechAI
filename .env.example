# Google OAuth (for user authentication)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Service Account (for Drive operations)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=

# Hugging Face (required for pyannote speaker diarization)
HF_AUTH_TOKEN=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# FastAPI
FASTAPI_PORT=8000
WHISPER_MODEL=base

# Optional AI Enhancement
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
